@model CreateBlogPostViewModel
@{
    ViewData["Title"] = "Edit Post";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <h1 class="display-5 mb-4">Edit Post</h1>
            
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">English Content</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="TitleEn" class="form-label"></label>
                            <input asp-for="TitleEn" class="form-control form-control-lg" />
                            <span asp-validation-for="TitleEn" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="ExcerptEn" class="form-label"></label>
                            <textarea asp-for="ExcerptEn" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="ExcerptEn" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="ContentEn" class="form-label"></label>
                            <textarea asp-for="ContentEn" class="form-control" rows="10"></textarea>
                            <span asp-validation-for="ContentEn" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Arabic Content (المحتوى العربي)</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="TitleAr" class="form-label"></label>
                            <input asp-for="TitleAr" class="form-control form-control-lg" dir="rtl" />
                            <span asp-validation-for="TitleAr" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="ExcerptAr" class="form-label"></label>
                            <textarea asp-for="ExcerptAr" class="form-control" rows="2" dir="rtl"></textarea>
                            <span asp-validation-for="ExcerptAr" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="ContentAr" class="form-label"></label>
                            <textarea asp-for="ContentAr" class="form-control" rows="10" dir="rtl"></textarea>
                            <span asp-validation-for="ContentAr" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Post Settings</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FeaturedImageUrl" class="form-label"></label>
                                <input asp-for="FeaturedImageUrl" class="form-control" />
                                <span asp-validation-for="FeaturedImageUrl" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label class="form-label d-block">&nbsp;</label>
                                <div class="form-check">
                                    <input asp-for="IsFeatured" class="form-check-input" />
                                    <label asp-for="IsFeatured" class="form-check-label"></label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SeriesId" class="form-label"></label>
                                <select asp-for="SeriesId" class="form-select">
                                    <option value="">-- Select Series (Optional) --</option>
                                </select>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="ProjectId" class="form-label"></label>
                                <select asp-for="ProjectId" class="form-select">
                                    <option value="">-- Select Project (Optional) --</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="d-grid gap-2 d-md-flex justify-content-md-end mb-5">
                    <a asp-action="Dashboard" class="btn btn-secondary btn-lg">Cancel</a>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-save me-2"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
