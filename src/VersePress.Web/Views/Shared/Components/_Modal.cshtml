@*
    Modal Component - Displays modal dialog
    Parameters: (string id, string title, string? size)
    Sizes: sm, md, lg, xl
    Usage: Include this component, then use JavaScript to show/hide
*@

@{
    var parameters = Model as ValueTuple<string, string, string?>? ?? ("myModal", "Modal Title", "md");
    var id = parameters.Item1;
    var title = parameters.Item2;
    var size = parameters.Item3 ?? "md";
}

<div class="modal fade" id="@id" tabindex="-1" aria-labelledby="@(id)Label" aria-hidden="true">
    <div class="modal-dialog modal-@size modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="@(id)Label">@title</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @RenderBody()
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary">Save changes</button>
            </div>
        </div>
    </div>
</div>
