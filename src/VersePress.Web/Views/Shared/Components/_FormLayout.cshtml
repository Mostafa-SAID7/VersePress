@*
    Form Layout Component
    
    A reusable layout wrapper for forms with consistent styling.
    Provides a centered, responsive card layout with title, subtitle, and footer.
    
    Usage in your view:
    @{
        ViewData["FormTitle"] = "Login";
        ViewData["FormSubtitle"] = "Welcome back to VersePress";
        ViewData["FormWidth"] = "sm"; // sm, md, lg, xl
        ViewData["FormFooter"] = "<p>Don't have an account? <a href='/register'>Register</a></p>";
    }
    <partial name="Components/_FormLayout">
        <form asp-action="Login" method="post">
            <!-- Your form content here -->
        </form>
    </partial>
    
    Parameters (via ViewData):
    - FormTitle: Form heading (required)
    - FormSubtitle: Optional subtitle below title
    - FormWidth: sm (400px), md (600px), lg (800px), xl (1000px) - default: md
    - FormFooter: Optional HTML content for footer
    - FormCardClass: Additional CSS classes for the card
    - FormNoCard: Set to "true" to remove card wrapper
*@

@{
    var title = ViewData["FormTitle"]?.ToString() ?? "Form";
    var subtitle = ViewData["FormSubtitle"]?.ToString();
    var width = ViewData["FormWidth"]?.ToString() ?? "md";
    var footer = ViewData["FormFooter"]?.ToString();
    var cardClass = ViewData["FormCardClass"]?.ToString() ?? "";
    var noCard = ViewData["FormNoCard"]?.ToString() == "true";
    
    var colClass = width switch {
        "sm" => "col-md-5 col-lg-4",
        "md" => "col-md-6",
        "lg" => "col-md-8",
        "xl" => "col-md-10",
        _ => "col-md-6"
    };
}

<div class="form-layout-container">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="@colClass">
                @if (!noCard)
                {
                    <div class="card shadow @cardClass">
                        <div class="card-body p-4 p-md-5">
                            <h2 class="form-layout-title text-center mb-1">@title</h2>
                            @if (!string.IsNullOrEmpty(subtitle))
                            {
                                <p class="form-layout-subtitle text-center text-muted mb-4">@subtitle</p>
                            }
                            else
                            {
                                <div class="mb-4"></div>
                            }
                            
                            <div class="form-layout-content">
                                @RenderBody()
                            </div>
                            
                            @if (!string.IsNullOrEmpty(footer))
                            {
                                <div class="form-layout-footer text-center mt-4">
                                    @Html.Raw(footer)
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="form-layout-no-card">
                        <h2 class="form-layout-title text-center mb-1">@title</h2>
                        @if (!string.IsNullOrEmpty(subtitle))
                        {
                            <p class="form-layout-subtitle text-center text-muted mb-4">@subtitle</p>
                        }
                        else
                        {
                            <div class="mb-4"></div>
                        }
                        
                        <div class="form-layout-content">
                            @RenderBody()
                        </div>
                        
                        @if (!string.IsNullOrEmpty(footer))
                        {
                            <div class="form-layout-footer text-center mt-4">
                                @Html.Raw(footer)
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
