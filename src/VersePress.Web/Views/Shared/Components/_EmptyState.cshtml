@model (string Icon, string Title, string Message, string ActionText, string ActionLink)

<div class="empty-state text-center py-5">
    <div class="empty-state-icon mb-4">
        <i class="bi bi-@Model.Icon"></i>
    </div>
    <h3 class="empty-state-title">@Model.Title</h3>
    <p class="empty-state-message text-muted">@Model.Message</p>
    @if (!string.IsNullOrEmpty(Model.ActionLink))
    {
        <a href="@Model.ActionLink" class="btn btn-primary mt-3">
            @Model.ActionText
        </a>
    }
</div>
