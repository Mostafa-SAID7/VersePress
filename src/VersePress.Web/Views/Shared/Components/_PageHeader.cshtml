@model (string Title, string Subtitle, string Icon, string ActionText, string ActionLink)

<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            @if (!string.IsNullOrEmpty(Model.Icon))
            {
                <i class="bi bi-@Model.Icon text-primary me-2 icon-md"></i>
            }
            <h1 class="display-5 d-inline-block mb-0">@Model.Title</h1>
            @if (!string.IsNullOrEmpty(Model.Subtitle))
            {
                <p class="lead text-muted mt-2">@Model.Subtitle</p>
            }
        </div>
        @if (!string.IsNullOrEmpty(Model.ActionLink))
        {
            <div>
                <a href="@Model.ActionLink" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-circle me-2"></i>@Model.ActionText
                </a>
            </div>
        }
    </div>
    <hr class="mt-3" />
</div>
