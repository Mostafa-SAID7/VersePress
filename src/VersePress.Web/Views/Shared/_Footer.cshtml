@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<footer class="border-top footer text-muted">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center py-3">
            <div class="footer-copyright mb-2 mb-md-0">
                &copy; @DateTime.Now.Year <a href="https://m-said-portfolio.netlify.app" target="_blank" rel="noopener noreferrer" class="footer-link">M.Said</a> - VersePress
            </div>
            <nav class="footer-nav">
                <ul class="list-inline mb-0">
                    <li class="list-inline-item">
                        <a asp-area="" asp-controller="Home" asp-action="About" class="footer-link">@Localizer["About"]</a>
                    </li>
                    <li class="list-inline-item">
                        <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-link">@Localizer["Privacy"]</a>
                    </li>
                    <li class="list-inline-item">
                        <a asp-area="" asp-controller="Home" asp-action="Terms" class="footer-link">@Localizer["Terms"]</a>
                    </li>
                    <li class="list-inline-item">
                        <a asp-area="" asp-controller="Home" asp-action="Contact" class="footer-link">@Localizer["Contact"]</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</footer>
