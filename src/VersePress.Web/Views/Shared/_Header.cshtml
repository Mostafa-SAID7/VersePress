@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<header>
    <nav class="navbar navbar-expand-md navbar-toggleable-md navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="~/favicon.svg" alt="VersePress Logo" class="navbar-logo me-2" />
                <span class="navbar-brand-text">VersePress</span>
            </a>
            <button class="navbar-toggler touch-target" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent"
                    aria-expanded="false" aria-label="@Localizer["ToggleNavigation"]">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse" id="navbarContent">
                <ul class="navbar-nav mx-auto mb-2 mb-md-0">
                    <li class="nav-item">
                        <a class="nav-link text-dark touch-target" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door"></i> @Localizer["Home"]
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark touch-target" asp-area="" asp-controller="Blog" asp-action="Index">
                            <i class="bi bi-newspaper"></i> Blog
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark touch-target" asp-area="" asp-controller="Home" asp-action="About">
                            <i class="bi bi-info-circle"></i> About
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark touch-target" asp-area="" asp-controller="Home" asp-action="Contact">
                            <i class="bi bi-envelope"></i> Contact
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark touch-target" asp-area="" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="bi bi-speedometer2"></i> Admin
                                </a>
                            </li>
                        }
                        else if (User.IsInRole("Author"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark touch-target" asp-area="" asp-controller="Author" asp-action="Dashboard">
                                    <i class="bi bi-pencil-square"></i> Author
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark touch-target" asp-area="" asp-controller="Account" asp-action="Profile">
                                <i class="bi bi-person-circle"></i> Profile
                            </a>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="nav-link text-dark touch-target btn btn-link">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark touch-target" asp-area="" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark touch-target" asp-area="" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus"></i> Register
                            </a>
                        </li>
                    }
                </ul>
                <div class="d-flex align-items-center flex-column flex-md-row mt-2 mt-md-0 gap-2">
                    <partial name="_ThemeToggle" />
                    <partial name="_LanguageSwitcher" />
                </div>
            </div>
        </div>
    </nav>
</header>
