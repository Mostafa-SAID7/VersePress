@using VersePress.Application.DTOs
@model OpenGraphDto

@if (Model != null)
{
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="@Model.Type" />
    <meta property="og:url" content="@Model.Url" />
    <meta property="og:title" content="@Model.Title" />
    <meta property="og:description" content="@Model.Description" />
    
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <meta property="og:image" content="@Model.ImageUrl" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content="@Model.Title" />
    }
    
    <meta property="og:site_name" content="@Model.SiteName" />
    <meta property="og:locale" content="@Model.Locale" />
    
    @if (!string.IsNullOrEmpty(Model.AlternateLocale))
    {
        <meta property="og:locale:alternate" content="@Model.AlternateLocale" />
    }
    
    @if (!string.IsNullOrEmpty(Model.AuthorName))
    {
        <meta property="article:author" content="@Model.AuthorName" />
    }
    
    @if (Model.PublishedTime.HasValue)
    {
        <meta property="article:published_time" content="@Model.PublishedTime.Value.ToString("yyyy-MM-ddTHH:mm:ssZ")" />
    }
    
    @if (Model.ModifiedTime.HasValue)
    {
        <meta property="article:modified_time" content="@Model.ModifiedTime.Value.ToString("yyyy-MM-ddTHH:mm:ssZ")" />
    }
    
    @foreach (var tag in Model.Tags)
    {
        <meta property="article:tag" content="@tag" />
    }
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="@Model.Url" />
    <meta name="twitter:title" content="@Model.Title" />
    <meta name="twitter:description" content="@Model.Description" />
    
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <meta name="twitter:image" content="@Model.ImageUrl" />
        <meta name="twitter:image:alt" content="@Model.Title" />
    }
    
    <meta name="twitter:site" content="@@VersePressBlog" />
    <meta name="twitter:creator" content="@@VersePressBlog" />
}
else
{
    <!-- Default Open Graph tags -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path" />
    <meta property="og:title" content="@ViewData["Title"] - VersePress" />
    <meta property="og:description" content="VersePress - A modern bilingual blog platform for tech news and insights" />
    <meta property="og:site_name" content="VersePress" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Default Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@@VersePressBlog" />
}
