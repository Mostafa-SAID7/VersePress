@model VersePress.Application.DTOs.OpenGraphDto

@if (Model != null)
{
    <meta property="og:title" content="@Model.Title" />
    <meta property="og:description" content="@Model.Description" />
    <meta property="og:type" content="@Model.Type" />
    <meta property="og:url" content="@Model.Url" />
    
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <meta property="og:image" content="@Model.ImageUrl" />
    }
    
    <meta property="og:site_name" content="@Model.SiteName" />
    <meta property="og:locale" content="@Model.Locale" />
    
    @if (!string.IsNullOrEmpty(Model.AlternateLocale))
    {
        <meta property="og:locale:alternate" content="@Model.AlternateLocale" />
    }
    
    @if (Model.PublishedTime.HasValue)
    {
        <meta property="article:published_time" content="@Model.PublishedTime.Value.ToString("o")" />
    }
    
    @if (Model.ModifiedTime.HasValue)
    {
        <meta property="article:modified_time" content="@Model.ModifiedTime.Value.ToString("o")" />
    }
    
    @if (!string.IsNullOrEmpty(Model.AuthorName))
    {
        <meta property="article:author" content="@Model.AuthorName" />
    }
    
    @if (Model.Tags != null && Model.Tags.Any())
    {
        foreach (var tag in Model.Tags)
        {
            <meta property="article:tag" content="@tag" />
        }
    }
    
    @* Twitter Card tags *@
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@Model.Title" />
    <meta name="twitter:description" content="@Model.Description" />
    
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <meta name="twitter:image" content="@Model.ImageUrl" />
    }
}
