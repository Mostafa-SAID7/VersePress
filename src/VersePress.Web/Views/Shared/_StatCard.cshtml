@model (string Icon, string Title, string Value, string Color, string Link, string LinkText)

<div class="card text-center shadow-sm stat-card h-100 @Model.Color">
    <div class="card-body">
        <i class="bi bi-@Model.Icon stat-icon"></i>
        <h3 class="stat-value mt-3">@Model.Value</h3>
        <p class="stat-title mb-0">@Model.Title</p>
        @if (!string.IsNullOrEmpty(Model.Link))
        {
            <a href="@Model.Link" class="btn btn-sm btn-outline-light mt-3">
                @Model.LinkText <i class="bi bi-arrow-right ms-1"></i>
            </a>
        }
    </div>
</div>

<style>
    .stat-card {
        transition: transform 0.3s ease;
        color: white;
    }
    .stat-card:hover {
        transform: scale(1.05);
    }
    .stat-card.bg-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .stat-card.bg-success {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }
    .stat-card.bg-info {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }
    .stat-card.bg-warning {
        background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
    }
    .stat-card.bg-danger {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }
    .stat-icon {
        font-size: 2.5rem;
        opacity: 0.9;
    }
    .stat-value {
        font-size: 2rem;
        font-weight: bold;
        margin: 0;
    }
    .stat-title {
        font-size: 0.9rem;
        opacity: 0.9;
    }
</style>
