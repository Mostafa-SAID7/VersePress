@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    var requestCultureFeature = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCultureFeature?.RequestCulture.Culture.Name ?? "en-US";
    var isRtl = currentCulture == "ar-SA";
    var dir = isRtl ? "rtl" : "ltr";
    var lang = isRtl ? "ar" : "en";
    var theme = Context.Items["Theme"]?.ToString() ?? "light";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    @* SEO Meta Tags - Can be overridden by individual pages *@
    @await Html.PartialAsync("_MetaTags", ViewData["MetaTags"])
    
    @* Open Graph & Twitter Cards *@
    @await Html.PartialAsync("_OpenGraph", ViewData["OpenGraph"])
    
    @* JSON-LD Structured Data *@
    @await Html.PartialAsync("_JsonLd", ViewData["JsonLd"])
    
    @* Favicon *@
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="apple-touch-icon" href="~/favicon.svg" />
    <link rel="shortcut icon" href="~/favicon.svg" />
    
    @* Performance optimizations *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link href="https://fonts.googleapis.com/css2?family=Exo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />
    
    @* Additional head content from pages *@
    @await RenderSectionAsync("Head", required: false)
    
    @* Google Analytics *@
    @await Html.PartialAsync("_GoogleAnalytics")
    
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @if (isRtl)
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    }
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VersePress.Web.styles.css" asp-append-version="true" />
</head>
<body class="@(isRtl ? "rtl" : "ltr") theme-@theme" data-theme="@theme">
    <partial name="_Header" />
    <partial name="_MobileSidebar" />
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <partial name="_Footer" />

    @* Toaster Component for notifications *@
    <partial name="Components/_Toaster" />

    <script src="~/lib/jquery/dist/jquery.min.js" defer></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="https://cdn.lordicon.com/lordicon.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.12.2/lottie.min.js" integrity="sha512-jEnuDt6jfecCjthQAJ+ed0MTVA++5ZKmlUcmDGBv2vUI/REn6FuIdixLNnQT+vKusE2hhTk2is3cFvv5wA+Sgg==" crossorigin="anonymous" referrerpolicy="no-referrer" defer></script>
    <script src="~/js/components.js" asp-append-version="true" defer></script>
    <script src="~/js/accessibility.js" asp-append-version="true" defer></script>
    <script src="~/js/site.js" asp-append-version="true" defer></script>
    <script src="~/js/animations.js" asp-append-version="true" defer></script>
    <script src="~/js/lordicon.js" asp-append-version="true" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
