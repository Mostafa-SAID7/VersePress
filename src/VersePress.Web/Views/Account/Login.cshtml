@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    ViewData["FormTitle"] = "Login";
    ViewData["FormSubtitle"] = "Welcome back to VersePress";
    ViewData["FormWidth"] = "sm";
    ViewData["FormFooter"] = "<p>Don't have an account? <a asp-action=\"Register\">Register here</a></p>";
}

<partial name="Components/_FormLayout">
    <form asp-action="Login" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
        
        <partial name="Components/_TextInput" model='new { 
            Id = "Email", 
            Name = "Email", 
            Label = "Email Address", 
            Type = "email", 
            Required = true,
            Autofocus = true,
            Value = Model?.Email
        }' />
        
        <partial name="Components/_TextInput" model='new { 
            Id = "Password", 
            Name = "Password", 
            Label = "Password", 
            Type = "password", 
            Required = true,
            Value = Model?.Password
        }' />
        
        <partial name="Components/_Checkbox" model='new { 
            Id = "RememberMe", 
            Name = "RememberMe", 
            Label = "Remember me",
            Checked = Model?.RememberMe ?? false
        }' />
        
        <div class="d-grid mt-4">
            <button type="submit" class="btn btn-primary btn-lg">Login</button>
        </div>
    </form>
</partial>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
