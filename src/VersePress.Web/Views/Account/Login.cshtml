@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="form-layout-container">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card shadow">
                    <div class="card-body p-4 p-md-5">
                        <h2 class="form-layout-title text-center mb-1">Login</h2>
                        <p class="form-layout-subtitle text-center text-muted mb-4">Welcome back to VersePress</p>
                        
                        <div class="form-layout-content">
                            <form asp-action="Login" method="post">
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                                
                                <partial name="Components/_TextInput" model='new { 
                                    Id = "Email", 
                                    Name = "Email", 
                                    Label = "Email Address", 
                                    Type = "email", 
                                    Required = true,
                                    Autofocus = true,
                                    Value = Model?.Email
                                }' />
                                
                                <partial name="Components/_TextInput" model='new { 
                                    Id = "Password", 
                                    Name = "Password", 
                                    Label = "Password", 
                                    Type = "password", 
                                    Required = true,
                                    Value = Model?.Password
                                }' />
                                
                                <partial name="Components/_Checkbox" model='new { 
                                    Id = "RememberMe", 
                                    Name = "RememberMe", 
                                    Label = "Remember me",
                                    Checked = Model?.RememberMe ?? false
                                }' />
                                
                                <div class="d-grid mt-4">
                                    <button type="submit" class="btn btn-primary btn-lg">Login</button>
                                </div>
                            </form>
                        </div>
                        
                        <div class="form-layout-footer text-center mt-4">
                            <p>Don't have an account? <a asp-action="Register">Register here</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
