@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card shadow">
                <div class="card-body p-5">
                    <lord-icon
                        src="https://cdn.lordicon.com/tdrtiskw.json"
                        trigger="loop"
                        class="lordicon-container"
                        style="width:150px;height:150px">
                    </lord-icon>
                    
                    <h1 class="display-4 mt-4">Access Denied</h1>
                    <p class="lead">You don't have permission to access this page.</p>
                    <p class="text-muted">If you believe this is an error, please contact the administrator.</p>
                    
                    <div class="mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Go to Homepage</a>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
