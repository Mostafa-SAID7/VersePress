@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
    ViewData["FormTitle"] = "Create Account";
    ViewData["FormSubtitle"] = "Join the VersePress community";
    ViewData["FormWidth"] = "md";
    ViewData["FormFooter"] = "<p>Already have an account? <a asp-action=\"Login\">Login here</a></p>";
}

<partial name="Components/_FormLayout">
    <form asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
        
        <partial name="Components/_TextInput" model='new { 
            Id = "FullName", 
            Name = "FullName", 
            Label = "Full Name", 
            Type = "text", 
            Required = true,
            Value = Model?.FullName
        }' />
        
        <partial name="Components/_TextInput" model='new { 
            Id = "UserName", 
            Name = "UserName", 
            Label = "Username", 
            Type = "text", 
            Required = true,
            Value = Model?.UserName
        }' />
        
        <partial name="Components/_TextInput" model='new { 
            Id = "Email", 
            Name = "Email", 
            Label = "Email Address", 
            Type = "email", 
            Required = true,
            Value = Model?.Email
        }' />
        
        <partial name="Components/_TextInput" model='new { 
            Id = "Password", 
            Name = "Password", 
            Label = "Password", 
            Type = "password", 
            Required = true,
            Value = Model?.Password
        }' />
        
        <partial name="Components/_TextInput" model='new { 
            Id = "ConfirmPassword", 
            Name = "ConfirmPassword", 
            Label = "Confirm Password", 
            Type = "password", 
            Required = true,
            Value = Model?.ConfirmPassword
        }' />
        
        <partial name="Components/_TextArea" model='new { 
            Id = "Bio", 
            Name = "Bio", 
            Label = "Bio (Optional)", 
            Rows = 3,
            Value = Model?.Bio
        }' />
        
        <div class="d-grid mt-4">
            <button type="submit" class="btn btn-primary btn-lg">Register</button>
        </div>
    </form>
</partial>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
