@using VersePress.Application.DTOs
@model IEnumerable<BlogPostDto>
@{
    ViewData["Title"] = "Manage Posts";
}

<div class="container-fluid mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">Manage Posts</h1>
        <a asp-controller="Author" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>New Post
        </a>
    </div>
    
    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Author</th>
                                <th>Status</th>
                                <th>Views</th>
                                <th>Comments</th>
                                <th>Published</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var post in Model)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Blog" asp-action="Details" asp-route-slug="@post.Slug">
                                            @post.TitleEn
                                        </a>
                                    </td>
                                    <td>@post.AuthorName</td>
                                    <td>
                                        @if (post.PublishedAt.HasValue)
                                        {
                                            <span class="badge bg-success">Published</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Draft</span>
                                        }
                                    </td>
                                    <td>@post.ViewCount</td>
                                    <td>@post.CommentCount</td>
                                    <td>@post.PublishedAt?.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <a asp-controller="Author" asp-action="Edit" asp-route-id="@post.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <p class="lead">No posts found.</p>
                </div>
            }
        </div>
    </div>
</div>
