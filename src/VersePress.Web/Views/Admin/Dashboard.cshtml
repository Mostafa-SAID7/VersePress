@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-5">
    <h1 class="display-5 mb-4">Admin Dashboard</h1>
    
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card text-center shadow-sm bg-primary text-white">
                <div class="card-body">
                    <i class="bi bi-file-text" style="font-size: 2.5rem;"></i>
                    <h2 class="mt-2">@Model.TotalPosts</h2>
                    <p class="mb-0">Total Posts</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center shadow-sm bg-success text-white">
                <div class="card-body">
                    <i class="bi bi-people" style="font-size: 2.5rem;"></i>
                    <h2 class="mt-2">@Model.TotalUsers</h2>
                    <p class="mb-0">Total Users</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center shadow-sm bg-info text-white">
                <div class="card-body">
                    <i class="bi bi-chat" style="font-size: 2.5rem;"></i>
                    <h2 class="mt-2">@Model.TotalComments</h2>
                    <p class="mb-0">Total Comments</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center shadow-sm bg-warning text-dark">
                <div class="card-body">
                    <i class="bi bi-clock-history" style="font-size: 2.5rem;"></i>
                    <h2 class="mt-2">@Model.PendingComments</h2>
                    <p class="mb-0">Pending Comments</p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Top Posts by Views</h5>
                </div>
                <div class="card-body">
                    @if (Model.TopPostsByViews != null && Model.TopPostsByViews.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var post in Model.TopPostsByViews.Take(5))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>@post.Title</span>
                                    <span class="badge bg-primary rounded-pill">@post.Count views</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No data available</p>
                    }
                </div>
            </div>
        </div>
        
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Recent Activity</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Activity feed coming soon...</p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2 d-md-flex">
                        <a asp-action="Posts" class="btn btn-primary">
                            <i class="bi bi-file-text me-2"></i>Manage Posts
                        </a>
                        <a asp-action="Comments" class="btn btn-warning">
                            <i class="bi bi-chat me-2"></i>Review Comments
                        </a>
                        <a asp-action="Users" class="btn btn-success">
                            <i class="bi bi-people me-2"></i>Manage Users
                        </a>
                        <a asp-action="Analytics" class="btn btn-info">
                            <i class="bi bi-graph-up me-2"></i>View Analytics
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
